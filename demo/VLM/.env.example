# 이 파일을 .env 로 복사한 뒤 키를 채우세요. (.env 는 git에 커밋하지 않습니다)

# Gemini 비전 API (gemini 백엔드) — 무료 티어. https://aistudio.google.com 에서 발급
# GEMINI_API_KEY=...

# Claude 비전 API (anthropic 백엔드) — 유료(선불 크레딧)
# ANTHROPIC_API_KEY=sk-ant-...

# GPT-4o 비전 API (openai 백엔드)
# OPENAI_API_KEY=sk-...

# 백엔드/모델을 환경변수로 강제 지정 (config/default.yaml 보다 우선)
# VLM_BACKEND=anthropic
# VLM_MODEL=claude-opus-4-8

# Roboflow 데이터셋 다운로드 (실제 도로 데이터 확보) — https://roboflow.com 무료 키
# ROBOFLOW_API_KEY=...
# ROBOFLOW_WORKSPACE=...
# ROBOFLOW_PROJECT=...
# ROBOFLOW_VERSION=1
