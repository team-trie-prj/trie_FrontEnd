# 백엔드 API 베이스 URL — 서버 미배포 상태.
# 로컬 백엔드 기동 시 비워두면 /api (vite 프록시 → localhost:8000), 배포 시 실제 주소 지정.
VITE_API_BASE_URL=

# 카카오 로그인 (Kakao Developers REST API 키 / 리다이렉트 URI — API 명세 기준 콜백 경로)
VITE_KAKAO_CLIENT_ID=
VITE_KAKAO_REDIRECT_URI=http://localhost:5173/oauth/kakao/callback

# true면 mock 데이터로 동작 (백엔드 없이 개발) — 서버 배포 후 false로 전환
VITE_USE_MOCK=true
